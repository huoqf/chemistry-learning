{
  "name": "chemistry-learning",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "node scripts/check-font-size.mjs && node scripts/check-no-raf.mjs && node scripts/check-no-marker.mjs && node scripts/check-large-files.mjs && node scripts/check-no-webgl-leak.mjs",
    "lint:ox": "oxlint",
    "preview": "vite preview",
    "check:font-size": "node scripts/check-font-size.mjs",
    "check:large-files": "node scripts/check-large-files.mjs",
    "check:no-raf": "node scripts/check-no-raf.mjs",
    "check:no-marker": "node scripts/check-no-marker.mjs",
    "check:no-webgl-leak": "node scripts/check-no-webgl-leak.mjs",
    "check:architecture": "npm run check:font-size && npm run check:large-files && npm run check:no-raf && npm run check:no-marker && npm run check:no-webgl-leak",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci": "npm run lint && npm run test:run && npm run build"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "idb": "^8.0.3",
    "katex": "^0.18.0",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "three": "^0.185.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.4",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
